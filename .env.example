# Frontend (Vite) — required
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: client-side Solana RPC for the checkout transfer.
# If unset, the browser falls back to the public mainnet RPC (rate-limited).
# The verifier on the server uses HELIUS_API_KEY / SOLANA_RPC_URL set in
# the Supabase Edge Function secrets, NOT here.
VITE_HELIUS_API_KEY=

# ---------------------------------------------------------------------------
# Edge Function secrets — set in the Supabase dashboard, NOT in this file.
# ---------------------------------------------------------------------------
#   HELIUS_API_KEY    or SOLANA_RPC_URL
#   ALCHEMY_API_KEY   or POLYGON_RPC_URL
#   (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.)
